# Database
DATABASE_URL="postgresql://postgres:yourpassword@localhost:5432/tradingdb?schema=public"

# 32-byte hex key for encrypting exchange API secrets.
# Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY="change-this-to-a-random-32-byte-hex-key-in-production"

# App
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Optional local proxy for exchange API requests.
# HTTPS_PROXY="http://127.0.0.1:7890"
# HTTP_PROXY="http://127.0.0.1:7890"
