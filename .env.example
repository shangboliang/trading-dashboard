# 数据库配置
DATABASE_URL="postgresql://postgres:yourpassword@localhost:5432/tradingdb?schema=public"

# 加密密钥 (32 字节 hex 字符串，用于加密 API Secrets)
# 生成方法：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY="change-this-to-a-random-32-byte-hex-key-in-production"

# 应用配置
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# 默认用户 ID (开发环境使用，生产环境请删除)
DEFAULT_USER_ID=1
